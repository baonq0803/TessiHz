# ============================================
#  TessiHz — Environment Variables (example)
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Session — THAY BẰNG CHUỖI NGẮN NGUYÊN TẦU NGẪU NHIÊN (ít nhất 32 ký tự)
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars-long!

# CORS — danh sách origins được phép (phân cách bằng dấu phẩy)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Cookie domain (chỉ cần khi deploy HTTPS)
# COOKIE_DOMAIN=.yourdomain.com
